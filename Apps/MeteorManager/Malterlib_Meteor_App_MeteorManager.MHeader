%Target "Tool_Malterlib_BuildMeteor"
{
	Property
	{
		MalterlibPostCopyProject "Malterlib_Meteor_MeteorManager"
		{
			!!MalterlibPostCopyProject ""
		}
		
		MalterlibPostCopySources "@(Target.OutputDirectory)@(MalterlibMeteorToolBuildName).tar.*;@(MalterlibPostCopySources)"
		MalterlibBuildServerPutSources "@(Target.OutputDirectory)@(MalterlibMeteorToolBuildName).tar.*;@(MalterlibBuildServerPutSources)"
		MeteorBuildDirectory "@(MalterlibMeteorToolBuildDirectory->MakeAbsolute('@(MalterlibMeteorSourceRoot)'))"
	}
	Property
	{
		BuildScript ""
		BuildScript "@('Source/Malterlib_Meteor_BuildMeteor.sh'->MakeAbsolute())"
		{
			&
			{
				BuildScript ""
				MalterlibMeteorToolType Meteor
			}
		}
		BuildScript "@('Source/Malterlib_Meteor_BuildExecutable.sh'->MakeAbsolute())"
		{
			&
			{
				BuildScript ""
				|
				{
					MalterlibMeteorToolType FastCGI
					MalterlibMeteorToolType Websocket
				}
			}
		}
		BuildScript "@('Source/Malterlib_Meteor_BuildNpm.sh'->MakeAbsolute())"
		{
			&
			{
				BuildScript ""
				MalterlibMeteorToolType Npm
			}
		}
		BuildScript "@('Source/Malterlib_Meteor_BuildStatic.sh'->MakeAbsolute())"
		{
			&
			{
				BuildScript ""
				MalterlibMeteorToolType Static
			}
		}
		BuildScript "@(MalterlibMeteorCustomBuildScript)"
		{
			&
			{
				BuildScript ""
				MalterlibMeteorToolType Custom
			}
		}
		BuildScript "@(Error('Missing build script. For custom builds specify with CustomBuildScript_@(MalterlibMeteorToolBuildName)'))"
		{
			!!BuildScript ""
		}
		
		ExcludeFiles "*/.DS_Store;*/.build.*;*/.gitignore;*/.git;*/node_modules;*/.npm;*/build;@(ExcludeFiles)"
		MalterlibMeteorToolExcludePatterns "@(MalterlibMeteorToolExcludePatterns->Replace('`','*'))"
		MalterlibMeteorToolExcludePatterns "@(MalterlibMeteorToolExcludePatterns->Replace('´',';'))"

		MalterlibMeteorToolDependencies "@(MalterlibMeteorToolDependencies->Replace('´',';'))"

		ExcludeFiles "@(MalterlibMeteorToolExcludePatterns);@(ExcludeFiles)"
		OutputDirectory "@(Target.OutputDirectory)"
		MeteorCommand "meteor"
		MeteorCommand "meteor.bat"
		{
			!!PlatformFamily Windows
		}
		MalterlibExportEnvironmentMinGW true

		Explodee_TargetIdentity "@(GetProperty('Property', 'TargetIdentity', '@(Explodee)'))"
		Explodee_MatchesDependencies "true"
		{
			|
			{
				MalterlibMeteorToolDependencies "@(Explodee_TargetIdentity)"
				MalterlibMeteorToolDependencies "~*;@(Explodee_TargetIdentity);*"
				MalterlibMeteorToolDependencies "~*;@(Explodee_TargetIdentity)"
				MalterlibMeteorToolDependencies "~@(Explodee_TargetIdentity);*"
				MalterlibMeteorToolDependencies "~*;@(Explodee_TargetIdentity)=*"
				MalterlibMeteorToolDependencies "~@(Explodee_TargetIdentity)=*"
			}
		}

		MalterlibMeteorToolDependenciesFiles_TargetFiles "@(GetProperty('Property', 'MalterlibCloud_VersionUploadSources', '@(Explodee)'))"

		MalterlibMeteorToolDependenciesFiles_Template "@(MalterlibMeteorToolDependenciesFiles_TargetFiles)"
		{
			&
			{
				!Explodee ""
				Explodee_MatchesDependencies true
			}
		}

		MalterlibMeteorToolDependenciesFiles "@(ExplodeList('@(Target.Dependencies)', ';', 'MalterlibMeteorToolDependenciesFiles_Template'))"

		FirstDependencyExecutable_TargetExecutable "@(GetProperty('Property', 'TargetExecutable', '@(Explodee)'))"
		FirstDependencyExecutable_TargetIsLaunchableExecutable "@(GetProperty('Property', 'TargetIsLaunchableExecutable', '@(Explodee)'))"

		FirstDependencyExecutable_Template "@(FirstDependencyExecutable_TargetExecutable)"
		{
			&
			{
				!Explodee ""
				ExplodedValue ""
				Explodee_MatchesDependencies true
				FirstDependencyExecutable_TargetIsLaunchableExecutable true
			}
		}

		FirstDependencyExecutable "@(Explode('@(Target.Dependencies)', ';', 'FirstDependencyExecutable_Template'))"
	}
	Target
	{
		Type "Tool"
		BaseName "BuildMeteor_@(MalterlibMeteorManagerName)_@(MalterlibMeteorToolBuildName)"
		CommandLine_Build "@(BashScriptPrefix)@(BuildScript) Build"
		CommandLine_ReBuild "@(BashScriptPrefix)@(BuildScript) Rebuild"
		CommandLine_Clean "@(BashScriptPrefix)@(BuildScript) Clean"
		
		ExportScriptEnvironment "MeteorCommand;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "OutputDirectory;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "MalterlibMeteorToolBuildName;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "MeteorBuildDirectory;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "MalterlibMeteorSharedPackages;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "PlatformFamily;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "MalterlibMeteorCheckedOutPath;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "MalterlibMeteorDebugBundle;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "MalterlibMeteorNodePackagePath;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "MalterlibMeteorHostNodePackagePath;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "MalterlibMeteorToolDependencies;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "MalterlibMeteorToolDependenciesFiles;@(Target.ExportScriptEnvironment)"
		ExportScriptEnvironment "NpmBuildType;@(Target.ExportScriptEnvironment)"

		Output "@(Builtin.GeneratorStateFile)"
		Group "Meteor/@(MalterlibMeteorManagerName)/@(MalterlibMeteorToolBuildName)"
	}
	%Group Build
	{
		%File "Source/Malterlib_Meteor_*.sh"
	}
	%Group SharedPackages
	{
		&
		{
			MalterlibMeteorToolType Meteor
			!MalterlibMeteorSharedPackages ""
		}
		
		%File "@(MalterlibMeteorSharedPackages)/^*"
	}
	%Group Source
	{
		Compile.AllowNonExisting true
		Property.ExcludeFiles "*/.meteor/local;@(ExcludeFiles)"
		%File "@(MeteorBuildDirectory)/^*"

		%Group packages
		{
			Compile
			{
				!!MalterlibCompileSupportTabSetings true
				IndentWidth 2
				TabWidth 2
				UsesTabs false
			}
			Property.ExcludeFiles "*/tests-proxy;@(ExcludeFiles)"
			%File "@(MeteorBuildDirectory)/packages/^*"
		}
	}
	%Dependency "@(MalterlibMeteorToolDependencies)"
}

%Target "Lib_Malterlib_MeteorManager"
{
	Property
	{
		MalterlibConcurrency_DistributedActors true
		MalterlibPostCopyProject ""
		MalterlibTargetNameType "Normal"
	}
	Target
	{
		BaseName "Malterlib_MeteorManager"
		Type StaticLibrary
		Group "Meteor"
	}
	Compile
	{
		!!CompileDialect "C"
		
		PreprocessorDefines "@(Compile.PreprocessorDefines)"
	}
	%Group Source
	{
		%File "Source/Malterlib_Meteor*"
		%File "Source/Malterlib_Meteor_App_MeteorManager_Server_DefaultCustomize.cpp"
		{
			Compile.Disabled true
		}
	}
	
	%Dependency "Lib_Malterlib_Cloud"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_Malterlib_Web"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_Malterlib_XML"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_Malterlib"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_zlib"
	{
		Dependency.Indirect true
	}
}

Property
{
	MeteorManagerEnvironmment "ROOT_URL(Meteor|FastCGI|Websocket|Npm)=RootURL;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "STATIC_ROOT_URL(Meteor|FastCGI|Websocket|Npm)=StaticRootURL;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "PORT(Meteor|FastCGI|Websocket|Npm)=LocalPort|8080;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "BIND_IP(Meteor|FastCGI|Websocket|Npm)=LocalIP;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "HTTP_FORWARDED_COUNT(Meteor|FastCGI|Websocket|Npm)=HttpForwardedCount|1;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "MAIL_URL(!Staging)=SMTP;@(MeteorManagerEnvironmment)"
	
	MeteorManagerEnvironmment "BUNDLE_PATH=PackageDirectory;@(MeteorManagerEnvironmment)"

	MeteorManagerEnvironmment "MONGO_URL=MongoURL;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "MONGO_OPLOG_URL=MongoOplogURL;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "MONGO_SSL_CA_FILE=MongoSSLCaFile;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "MONGO_SSL_CLIENT_CERT_FILE=MongoSSLClientCertFile;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "MONGO_SELF_ID=MongoSelfID;@(MeteorManagerEnvironmment)"
	
	MeteorManagerEnvironmment "METEOR_DDP_SELF=DDPSelf;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "METEOR_MANAGER_INSTANCE_ID=ManagerInstanceID;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "METEOR_MANAGER_NODE_INSTANCE_ID(!FastCGI,!Websocket)=LaunchInstanceID;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "METEOR_MANAGER_NODE_SEQUENCE(!FastCGI,!Websocket)=LaunchSequence;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "METEOR_MANAGER_LAUNCH_INSTANCE_ID(FastCGI|Websocket)=LaunchInstanceID;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "METEOR_MANAGER_LAUNCH_SEQUENCE(FastCGI|Websocket)=LaunchSequence;@(MeteorManagerEnvironmment)"
	MeteorManagerEnvironmment "METEOR_MANAGER_BACKEND_IDENTIFIER=BackendIdentifier;@(MeteorManagerEnvironmment)"
}

%Target "Malterlib_Meteor_MeteorManager"
{
	Property
	{
		ProductName "Malterlib Meteor Manager"
		ProductName "@(MalterlibMeteorManagerProductName)"
		{
			!MalterlibMeteorManagerProductName ""
		}
		MalterlibTestApp true
		MalterlibPostCopyProject "Malterlib_Meteor_MeteorManager"
		{
			!!MalterlibPostCopyProject ""
		}
		MalterlibLinkWithOpenSSL true
		MalterlibConcurrency_DistributedActors true
		MalterlibTargetNameType "Normal"

		MalterlibMeteorManagerUserNamePrefix "mib_"
		{
			!!MalterlibMeteorManagerUserNamePrefix ""
		}

		MalterlibMeteorManagerPrefix MeteorManager_
		{
			&
			{
				MalterlibMeteorManagerPrefix ""
				!MalterlibMeteorManagerPrefix "Empty"
			}
		}
		MalterlibMeteorManagerPrefix ""
		{
			!!MalterlibMeteorManagerPrefix "Empty"
		}

		MalterlibMeteorManagerDaemonName "@(Error('Use MalterlibMeteorManagerDaemonName instead'))"
		{
			!MalterlibMeteorManagerServiceName ""
		}

		MalterlibMeteorManagerDaemonName "MalterlibMeteorManager_@(MalterlibMeteorManagerName)"
		{
			&
			{
				MalterlibMeteorManagerDaemonName ""
				MalterlibMeteorManagerPrefix "MeteorManager_"
			}
		}
		MalterlibMeteorManagerDaemonName "@(MalterlibMeteorManagerPrefix)@(MalterlibMeteorManagerName)"
		{
			!!MalterlibMeteorManagerDaemonName ""
		}

		MalterlibMeteorManagerDescription "Malterlib Web App Manager (@(MalterlibMeteorManagerName))"
		{
			!!MalterlibMeteorManagerDescription ""
		}

		MalterlibCloudVersionInfo_Application "@(MalterlibMeteorManagerPrefix->Replace('_','-'))@(MalterlibMeteorManagerName)"
		MalterlibCloudVersionInfo_Executable "@(MalterlibMeteorManagerPrefix)@(MalterlibMeteorManagerName)"
		MalterlibCloud_EnableVersionUpload true
		
		MalterlibDoExeFS true

		MeteorManagerCopySources "@('Source/Malterlib_Meteor_App_MeteorManager_OSSetup.sh'->MakeAbsolute())|Source;@(MeteorManagerCopySources)"
		MeteorManagerCopySources "@('Source/Malterlib_Meteor_App_MeteorManager_Nginx.conf'->MakeAbsolute())|Source;@(MeteorManagerCopySources)"
		MeteorManagerCopySources "@('Source/Malterlib_Meteor_App_MeteorManager_FastCGI.conf'->MakeAbsolute())|Source;@(MeteorManagerCopySources)"
		MeteorManagerCopySources "@(MeteorManagerMongoDatabaseSetupScript)|Source;@(MeteorManagerCopySources)"
		{
			!MeteorManagerMongoDatabaseSetupScript ""
		}

		MalterlibExeFSExtraFiles "@(MeteorManagerCopySources);@(MalterlibExeFSExtraFiles)"
		{
			!MeteorManagerCopySources ""
		}
		MalterlibExeFSExtraFiles "@(NodeBinariesPath)/*;@(MalterlibExeFSExtraFiles)"
		{
			&
			{
				!NodeBinariesPath ""
				!BuildNeedNodeBinaries ""
			}
		}
		
		MalterlibMeteorNodePackagePath "@(NodeBinariesPath->FindFilesIn('*.tar.gz'))"
		{
			&
			{
				MalterlibMeteorNodePackagePath ""
				!NodeBinariesPath ""
			}
		}
		MalterlibMeteorHostNodePackagePath "@(NodeHostBinariesPath->FindFilesIn('*.tar.gz'))"
		{
			&
			{
				MalterlibMeteorHostNodePackagePath ""
				!NodeHostBinariesPath ""
			}
		}

		MalterlibMeteorSettingsPath "@(GeneratedDirectory)MeteorSettings.json"

	}
	Target
	{
		BaseName "@(MalterlibMeteorManagerPrefix)@(MalterlibMeteorManagerName)"
		DebuggerCommandArguments "--daemon-run-debug"
		BaseFileName "@(MalterlibMeteorManagerPrefix)@(MalterlibMeteorManagerName)"
		Group "Meteor/@(MalterlibMeteorManagerName)"
		ExtraGroups "{Malterlib}/{CloudTarBinaries};@(Target.ExtraGroups)"
	}
	Compile
	{
		!!CompileDialect "C"
		
		PrefixHeader "@('Source/Malterlib_Meteor_App_MeteorManager_Server.h'->MakeAbsolute())"
		
		PreprocessorDefines "DMibMeteor_ManagerName=\"@(MalterlibMeteorManagerName)\";@(Compile.PreprocessorDefines)"
		PreprocessorDefines "DMibMeteor_ManagerDescription=\"@(MalterlibMeteorManagerDescription)\";@(Compile.PreprocessorDefines)"
		PreprocessorDefines "DMibMeteor_SettingsPath=\"@(MalterlibMeteorSettingsPath)\";@(Compile.PreprocessorDefines)"
		PreprocessorDefines "DMibMeteor_ManagerDaemonName=\"@(MalterlibMeteorManagerDaemonName)\";@(Compile.PreprocessorDefines)"
		PreprocessorDefines "DMibMeteor_UseInternalNode;@(Compile.PreprocessorDefines)"
		{
			!NodeBinariesPath ""
		}
	}
	%Group Source
	{
		%File "Source/Main.cpp"
		%File "Source/Malterlib_Meteor_App_MeteorManager_Server_DefaultCustomize.cpp"
		{
			!!MeteorManagerCustomizationFile ""
		}
		%File "@(MeteorManagerCustomizationFile)"
		{
			!MeteorManagerCustomizationFile ""
		}
		%File "@(MeteorManagerExtraSources)"
	}
	%Group Settings
	{
		%GenerateFile "SettingsFile"
		{
			Property
			{
				Empty ""
				
				MeteorManagerMongoDefaultReplicaName "DefaultReplica"
				{
					!!MeteorManagerMongoDefaultReplicaName ""
				}
				
				BuildPackageType "Meteor" { !!BuildPackageNames_Meteor "~*;@(Explodee);*" }
				BuildPackageType "Npm" { !!BuildPackageNames_Npm "~*;@(Explodee);*" }
				BuildPackageType "Static" { !!BuildPackageNames_Static "~*;@(Explodee);*" }
				BuildPackageType "Custom" { !!BuildPackageNames_Custom "~*;@(Explodee);*" }
				BuildPackageType "FastCGI" { !!BuildPackageNames_FastCGI "~*;@(Explodee);*" }
				BuildPackageType "Websocket" { !!BuildPackageNames_Websocket "~*;@(Explodee);*" }

				BuildPackageType "Meteor" { !!BuildPackageNames_Meteor "~@(Explodee);*" }
				BuildPackageType "Npm" { !!BuildPackageNames_Npm "~@(Explodee);*" }
				BuildPackageType "Static" { !!BuildPackageNames_Static "~@(Explodee);*" }
				BuildPackageType "Custom" { !!BuildPackageNames_Custom "~@(Explodee);*" }
				BuildPackageType "FastCGI" { !!BuildPackageNames_FastCGI "~@(Explodee);*" }
				BuildPackageType "Websocket" { !!BuildPackageNames_Websocket "~@(Explodee);*" }

				BuildPackageType "Meteor" { !!BuildPackageNames_Meteor "~*;@(Explodee)" }
				BuildPackageType "Npm" { !!BuildPackageNames_Npm "~*;@(Explodee)" }
				BuildPackageType "Static" { !!BuildPackageNames_Static "~*;@(Explodee)" }
				BuildPackageType "Custom" { !!BuildPackageNames_Custom "~*;@(Explodee)" }
				BuildPackageType "FastCGI" { !!BuildPackageNames_FastCGI "~*;@(Explodee)" }
				BuildPackageType "Websocket" { !!BuildPackageNames_Websocket "~*;@(Explodee)" }

				BuildPackageType "Meteor" { !!BuildPackageNames_Meteor "@(Explodee)" }
				BuildPackageType "Npm" { !!BuildPackageNames_Npm "@(Explodee)" }
				BuildPackageType "Static" { !!BuildPackageNames_Static "@(Explodee)" }
				BuildPackageType "Custom" { !!BuildPackageNames_Custom "@(Explodee)" }
				BuildPackageType "FastCGI" { !!BuildPackageNames_FastCGI "@(Explodee)" }
				BuildPackageType "Websocket" { !!BuildPackageNames_Websocket "@(Explodee)" }

				BuildPackageType "@(Error('Package type could not be deduced for: @(Explodee)'))"
				{
					!!BuildPackageType ""
				}

				ToolTargetIdentifier "Group:Meteor.Group:@(MalterlibMeteorManagerName).Group:@(Explodee).Target:Tool_Malterlib_BuildMeteor.Target:Tool_Malterlib_BuildMeteor"

				CustomExecutable "@(Executable_@(Explodee))"
				CustomExecutable "@(GetProperty('Property', 'FirstDependencyExecutable', '@(ToolTargetIdentifier)'))"
				{
					&
					{
						CustomExecutable ""
						|
						{
							BuildPackageType "FastCGI"
							BuildPackageType "Websocket"
						}
					}
				}

				CustomParams "@(Params_@(Explodee))"
				CustomParams "--daemon-run-standalone"
				{
					&
					{
						CustomParams ""
						|
						{
							BuildPackageType "FastCGI"
							BuildPackageType "Websocket"
						}
					}
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"Type\": \"@(BuildPackageType)\",\n"


				PackageSettings	"@(PackageSettings)"\
								"			\"MemoryPerNode\": @(MemoryPerNode_@(Explodee)),\n"
				{
					!Empty "@(MemoryPerNode_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"Concurrency\": @(Concurrency_@(Explodee)),\n"
				{
					!Empty "@(Concurrency_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"CustomExecutable\": \"@(CustomExecutable)\",\n"
				{
					!Empty "@(CustomExecutable)"
				}

				Params_Template	"\"@(Explodee)\", "
				{
					!Explodee ""
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"CustomParams\": [@(Builtin.Function->ExplodeList('@(CustomParams)', ';', 'Params_Template'))],\n"
				{
					!Empty "@(CustomParams)"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"StaticPath\": \"@(StaticPath_@(Explodee))\",\n"
				{
					!Empty "@(StaticPath_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"UploadS3\": @(UploadS3_@(Explodee)),\n"
				{
					!Empty "@(UploadS3_@(Explodee))"
				}

				UploadS3Priority_Template_Expand "				\"@(Expand0)\": @(Expand1),\n"
				UploadS3Priority_Template	"@(Builtin.Function->ExpandList('@(Explodee)', '>', 'UploadS3Priority_Template_Expand'))"
				{
					!Explodee ""
				}
				PackageSettings	"@(PackageSettings)"\
								"			\"UploadS3Priority\": {\n"\
								"@(Builtin.Function->ExplodeList('@(UploadS3Priority_@(Explodee))', ';', 'UploadS3Priority_Template'))"\
								"			},\n"
				{
					!Empty "@(UploadS3Priority_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"ExternalRoot\": \"@(ExternalRoot_@(Explodee))\",\n"
				{
					!Empty "@(ExternalRoot_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"SeparateUser\": @(SeparateUser_@(Explodee)),\n"
				{
					!Empty "@(SeparateUser_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"OwnPackageDirectory\": @(OwnPackageDirectory_@(Explodee)),\n"
				{
					!Empty "@(OwnPackageDirectory_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"AllowRobots\": @(AllowRobots_@(Explodee)),\n"
				{
					!Empty "@(AllowRobots_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"NpmBuildType\": \"@(NpmBuildType_@(Explodee))\",\n"
				{
					!Empty "@(NpmBuildType_@(Explodee))"
				}

				StartupDependencies_Template	"\"@(Explodee)\", "
				{
					!Explodee ""
				}
				
				PackageSettings	"@(PackageSettings)"\
								"			\"StartupDependencies\": [@(Builtin.Function->ExplodeList('@(StartDependencies_@(Explodee))', ';', 'StartupDependencies_Template'))],\n"
				{
					!Empty "@(StartDependencies_@(Explodee))"
				}

				ExcludeGzipPatterns_Template	"\"@(Explodee)\", "
				{
					!Explodee ""
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"ExcludeGzipPatterns\": [@(Builtin.Function->ExplodeList('@(ExcludeGzipPatterns_@(Explodee))', ';', 'ExcludeGzipPatterns_Template'))],\n"
				{
					!Empty "@(ExcludeGzipPatterns_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"DomainPrefix\": \"@(DomainPrefix_@(Explodee))\",\n"
				{
					!Empty "@(DomainPrefix_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"SubPath\": \"@(SubPath_@(Explodee))\",\n"
				{
					!Empty "@(SubPath_@(Explodee))"
				}

				PackageSettings	"@(PackageSettings)"\
								"			\"RedirectsFile\": \"@(RedirectsFile_@(Explodee))\",\n"
				{
					!Empty "@(RedirectsFile_@(Explodee))"
				}
				
				PackageSettings	"@(PackageSettings)"\
								"			\"StickyCookie\": \"@(StickyCookie_@(Explodee))\",\n"
				{
					!Empty "@(StickyCookie_@(Explodee))"
				}
				
				PackageSettings	"@(PackageSettings)"\
								"			\"StickyHeader\": \"@(StickyHeader_@(Explodee))\",\n"
				{
					!Empty "@(StickyHeader_@(Explodee))"
				}

				
				PackageSettings_Template	"		\"@(Explodee)\": {\n"\
											"@(PackageSettings)"\
											"		},\n"
				{
					!Explodee ""
				}
			
				Name "@(MalterlibMeteorSettingsPath)"


				Contents	"R\"-----(\n"\
							"{\n"\
							"	\"Packages\": {\n"

				Contents	"@(Contents)"\
							"@(Builtin.Function->ExplodeList('@(BuildPackageNames)', ';', 'PackageSettings_Template'))"\
							"	},\n"

				Contents	"@(Contents)"\
							"	\"Mongo\": {\n"

				Contents	"@(Contents)"\
							"		\"Directory\": \"@(MeteorManagerMongoDirectory)\",\n"
				{
					!MeteorManagerMongoDirectory ""
				}
				Contents	"@(Contents)"\
							"		\"Host\": \"@(MeteorManagerMongoHost)\",\n"
				{
					!MeteorManagerMongoHost ""
				}
				Contents	"@(Contents)"\
