	Property
	{
		CheckError "@(Error('You need to specify MeteorBuilds, FastCGIBuilds, WebsocketBuilds, NpmBuilds, StaticBuilds, and/or CustomBuilds'))"
		{
			&
			{
				FastCGIBuilds ""
				WebsocketBuilds ""
				MeteorBuilds ""
				NpmBuilds ""
				StaticBuilds ""
				CustomBuilds ""
			}
		}

		BuildDependencies_ExcludePattern "@(ExcludePatterns_@(Expand0))"
		BuildDependencies_ExcludePattern "@(BuildDependencies_ExcludePattern->Replace('*','`'))"
		BuildDependencies_ExcludePattern "@(BuildDependencies_ExcludePattern->Replace(';','´'))"

		BuildDependencies_MalterlibMeteorToolDependencies "@(Dependencies_@(Expand0))"
		BuildDependencies_MalterlibMeteorToolDependencies "@(BuildDependencies_MalterlibMeteorToolDependencies->Replace(';','´'))"

		BuildDependencies_CommonProperties "MalterlibMeteorManagerName=@(MalterlibMeteorManagerName)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorToolBuildName=@(Expand0)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorToolBuildDirectory=@(Expand1)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorToolExcludePatterns=@(BuildDependencies_ExcludePattern)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorSourceRoot=@(MalterlibMeteorSourceRoot)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorSharedPackages=@(MalterlibMeteorSharedPackages)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorCustomBuildScript=@(CustomBuildScript_@(Expand0))*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorToolDependencies=@(BuildDependencies_MalterlibMeteorToolDependencies)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorCheckedOutPath=@(MalterlibMeteorCheckedOutPath)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorDebugBundle=@(MalterlibMeteorDebugBundle)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorNodePackagePath=@(MalterlibMeteorNodePackagePath)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorHostNodePackagePath=@(MalterlibMeteorHostNodePackagePath)*@(BuildDependencies_CommonProperties)"
		BuildDependencies_CommonProperties "MalterlibMeteorManagerPrefix=@(MalterlibMeteorManagerPrefix)*@(BuildDependencies_CommonProperties)"

		BuildDependencies_CommonProperties "NpmBuildType=@(NpmBuildType_@(Expand0))*@(BuildDependencies_CommonProperties)"
		{
