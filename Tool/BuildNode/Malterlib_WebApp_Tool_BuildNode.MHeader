Property
{
 	MalterlibWebAppBuildNode define bool = false // User(Node)=true: Support building mongo and mongo-tools binaries
}

%Repository "node"
{
	!!MalterlibWebAppBuildNode true

	Repository
	{
		Type "External"
		Remotes =+ {Name: "upstream", URL: "https://github.com/nodejs/node.git"}
	}
}
