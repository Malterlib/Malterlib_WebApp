Property
{
	MalterlibMeteorBuildNode "false" // User(Node)=true: Support building mongo and mongo-tools binaries
	{
		!!MalterlibMeteorBuildNode ""
	}
}

%Repository "node"
{
	!!MalterlibMeteorBuildNode true

	Repository
	{
		Type External
		Remotes "upstream=https://github.com/nodejs/node.git;@(Repository.Remotes)"
	}
}
